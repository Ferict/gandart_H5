# 内容域 provider 配置样例
# 默认开发可保持 mock；联调真实后端时改为 http

VITE_CONTENT_PROVIDER=mock
# VITE_CONTENT_PROVIDER=http
# VITE_CONTENT_API_BASE_URL=http://127.0.0.1:8080

# 五接口联调验证矩阵默认会直接校验：
# 1. GET /api/content/scene
# 2. GET /api/content/list
#
# 下面这些样本参数用于补齐 resource / action 两类接口。
# 未填写时，脚本会显式 SKIP，不会伪造假样本制造假失败。

# 默认 scene/list 样本
# VITE_CONTENT_SMOKE_SCENE_ID=home
# VITE_CONTENT_SMOKE_LIST_RESOURCE_TYPE=market_item
# VITE_CONTENT_SMOKE_LIST_PAGE=1
# VITE_CONTENT_SMOKE_LIST_PAGE_SIZE=20

# 可选 scene 上下文
# VITE_CONTENT_SMOKE_SCENE_PLATFORM=h5
# VITE_CONTENT_SMOKE_SCENE_CHANNEL=web
# VITE_CONTENT_SMOKE_SCENE_LOCALE=zh-CN

# 可选 resource 样本
# VITE_CONTENT_SMOKE_RESOURCE_TYPE=profile_asset
# VITE_CONTENT_SMOKE_RESOURCE_ID=C-04

# 可选 list 过滤样本
# VITE_CONTENT_SMOKE_LIST_CATEGORY_ID=collections
# VITE_CONTENT_SMOKE_LIST_SUB_CATEGORY=limited
# VITE_CONTENT_SMOKE_LIST_KEYWORD=数字藏品

# 可选 action 样本
# VITE_CONTENT_SMOKE_NOTICE_ID=notice_1001
# VITE_CONTENT_SMOKE_SERVICE_ID=orders
# VITE_CONTENT_SMOKE_LATEST_MESSAGE_ID=msg_1001
